# Call Insights Engine - Environment Variables
# Copy this file to .env and fill in your values

# Google Cloud Project Configuration
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# Google API Key (for direct Gemini API access)
GOOGLE_API_KEY=your-api-key

# Optional: RAG Corpus for business context
# RAG_CORPUS=projects/your-project/locations/us-central1/ragCorpora/your-corpus-id

# Processing Configuration
MAX_WORKERS=4
SAVE_INTERMEDIATE=false
OUTPUT_DIR=./output

# Logging
LOG_LEVEL=INFO

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key
